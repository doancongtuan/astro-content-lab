---
import ThemeToggle from './ThemeToggle.astro'
---

<header class="border-b border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 sticky top-0 z-50 transition-colors duration-200">
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between h-16">
    <a href="/" class="font-bold text-lg text-slate-900 dark:text-slate-100 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap flex-shrink-0">
      Astro <span class="text-indigo-600 dark:text-indigo-400">Content Lab</span>
    </a>

    <div class="flex items-center gap-2 flex-shrink-0">
      <ThemeToggle />
      <button class="menu-toggle hidden max-[768px]:flex flex-col gap-1.5 bg-transparent border-0 cursor-pointer p-1" aria-label="Toggle menu" aria-expanded="false">
        <span class="block w-5.5 h-0.5 bg-slate-900 dark:bg-slate-100 rounded transition-all"></span>
        <span class="block w-5.5 h-0.5 bg-slate-900 dark:bg-slate-100 rounded transition-all"></span>
        <span class="block w-5.5 h-0.5 bg-slate-900 dark:bg-slate-100 rounded transition-all"></span>
      </button>
    </div>

    <nav id="site-nav" class="flex gap-6 max-[768px]:hidden max-[768px]:absolute max-[768px]:top-16 max-[768px]:left-0 max-[768px]:right-0 max-[768px]:bg-white dark:max-[768px]:bg-slate-900 max-[768px]:border-b max-[768px]:border-slate-200 dark:max-[768px]:border-slate-700 max-[768px]:flex-col max-[768px]:px-5 max-[768px]:py-2 max-[768px]:shadow-md">
      <a href="/blog" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap max-[768px]:py-3 max-[768px]:border-b max-[768px]:border-slate-100 dark:max-[768px]:border-slate-800">Blog</a>
      <a href="/reviews" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap max-[768px]:py-3 max-[768px]:border-b max-[768px]:border-slate-100 dark:max-[768px]:border-slate-800">Reviews</a>
      <a href="/compares" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap max-[768px]:py-3 max-[768px]:border-b max-[768px]:border-slate-100 dark:max-[768px]:border-slate-800">Compares</a>
      <a href="/guides" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap max-[768px]:py-3 max-[768px]:border-b max-[768px]:border-slate-100 dark:max-[768px]:border-slate-800">Guides</a>
      <a href="/about" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline whitespace-nowrap max-[768px]:py-3">About</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle')
  const nav = document.querySelector('#site-nav')

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('!flex')
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
  })
</script>