---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Stay in the loop',
  description = 'New articles on Astro, WordPress, and the modern stack. No spam. Unsubscribe anytime.',
} = Astro.props
---

<div class="mt-12 rounded-2xl border border-indigo-100 dark:border-indigo-900 bg-indigo-50 dark:bg-indigo-950 p-6 sm:p-8">
  <div class="max-w-xl">
    <h2 class="text-xl font-bold text-indigo-900 dark:text-indigo-100 mb-1">{title}</h2>
    <p class="text-sm text-indigo-700 dark:text-indigo-300 mb-4">{description}</p>
    <div class="flex gap-2 flex-wrap sm:flex-nowrap">
      <input
        type="email"
        placeholder="your@email.com"
        class="flex-1 min-w-0 px-4 py-2.5 rounded-xl border border-indigo-200 dark:border-indigo-700 bg-white dark:bg-slate-800 text-sm text-gray-900 dark:text-slate-100 placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-400 dark:focus:ring-indigo-500"
      />
      <button
        type="button"
        class="px-5 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white text-sm font-semibold transition-colors duration-150 shrink-0"
      >
        Subscribe
      </button>
    </div>
    <p class="text-xs text-indigo-500 dark:text-indigo-400 mt-3">UI only — backend coming in a later article.</p>
  </div>
</div>