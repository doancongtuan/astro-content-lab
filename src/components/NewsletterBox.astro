---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'Stay in the loop',
  description = 'New articles on Astro, WordPress, and the modern stack. No spam. Unsubscribe anytime.',
} = Astro.props
---

<div class="mt-12 rounded-2xl border border-indigo-100 bg-indigo-50 p-6 sm:p-8">
  <div class="max-w-xl">
    <h2 class="text-xl font-bold text-indigo-900 mb-1">{title}</h2>
    <p class="text-sm text-indigo-700 mb-4">{description}</p>
    <div class="flex gap-2 flex-wrap sm:flex-nowrap">
      <input
        type="email"
        placeholder="your@email.com"
        class="flex-1 min-w-0 px-4 py-2.5 rounded-xl border border-indigo-200 bg-white text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400"
      />
      <button
        type="button"
        class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition-colors duration-150 shrink-0"
      >
        Subscribe
      </button>
    </div>
    <p class="text-xs text-indigo-500 mt-3">UI only — backend coming in a later article.</p>
  </div>
</div>