---
// src/components/content/VerdictBox.astro

interface Props {
  verdict: string
  rating?: number
  maxRating?: number
}

const { verdict, rating, maxRating = 5 } = Astro.props

function scoreBadgeClass(score: number, max: number): string {
  const ratio = score / max
  if (ratio >= 0.8) return 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300'
  if (ratio >= 0.6) return 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300'
  return 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300'
}
---

<div class="bg-indigo-50 dark:bg-indigo-950 border border-indigo-200 dark:border-indigo-800 rounded-xl p-5 mb-8">
  <div class="flex items-start justify-between gap-3">
    <p class="m-0">
      <strong class="text-indigo-900 dark:text-indigo-200">Verdict:</strong>
      <span class="text-indigo-800 dark:text-indigo-300"> {verdict}</span>
    </p>
    {typeof rating === 'number' && (
      <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${scoreBadgeClass(rating, maxRating)}`}>
        {rating.toFixed(1)}/{maxRating}
      </span>
    )}
  </div>
</div>