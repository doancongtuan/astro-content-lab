---
// src/components/content/ComparisonTable.astro

interface Factor {
  label: string
  left: string
  right: string
  winner?: 'left' | 'right' | 'tie'
}

interface Props {
  leftLabel: string
  rightLabel: string
  factors: Factor[]
}

const { leftLabel, rightLabel, factors } = Astro.props
---

<div class="overflow-x-auto mb-8 rounded-xl border border-slate-200 dark:border-slate-700">
  <table class="w-full border-collapse text-sm">
    <thead>
      <tr class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
        <th class="text-left font-semibold text-slate-700 dark:text-slate-300 px-4 py-3">Factor</th>
        <th class="text-left font-semibold text-slate-700 dark:text-slate-300 px-4 py-3">{leftLabel}</th>
        <th class="text-left font-semibold text-slate-700 dark:text-slate-300 px-4 py-3">{rightLabel}</th>
      </tr>
    </thead>
    <tbody>
      {factors.map((factor, i) => (
        <tr class={`border-b border-slate-100 dark:border-slate-700 ${i % 2 === 1 ? 'bg-slate-50/50 dark:bg-slate-800/50' : ''}`}>
          <td class="px-4 py-3 font-medium text-slate-700 dark:text-slate-300 align-top">{factor.label}</td>
          <td class={`px-4 py-3 align-top ${
            factor.winner === 'left'
              ? 'bg-emerald-100 dark:bg-emerald-900 border-l-4 border-emerald-500 text-emerald-900 dark:text-emerald-200 font-semibold'
              : 'text-slate-400 dark:text-slate-500'
          }`}>
            {factor.winner === 'left' && (
              <span class="inline-flex items-center gap-1 text-emerald-700 dark:text-emerald-400 text-xs font-bold uppercase tracking-wide mr-1.5" aria-hidden="true">
                <svg viewBox="0 0 20 20" class="w-3.5 h-3.5" fill="currentColor"><path d="M16.7 5.3a1 1 0 010 1.4l-7.4 7.4a1 1 0 01-1.4 0L3.3 9.5a1 1 0 111.4-1.4l3.6 3.6 6.7-6.7a1 1 0 011.4 0z"/></svg>
              </span>
            )}
            {factor.left}
          </td>
          <td class={`px-4 py-3 align-top ${
            factor.winner === 'right'
              ? 'bg-emerald-100 dark:bg-emerald-900 border-l-4 border-emerald-500 text-emerald-900 dark:text-emerald-200 font-semibold'
              : 'text-slate-400 dark:text-slate-500'
          }`}>
            {factor.winner === 'right' && (
              <span class="inline-flex items-center gap-1 text-emerald-700 dark:text-emerald-400 text-xs font-bold uppercase tracking-wide mr-1.5" aria-hidden="true">
                <svg viewBox="0 0 20 20" class="w-3.5 h-3.5" fill="currentColor"><path d="M16.7 5.3a1 1 0 010 1.4l-7.4 7.4a1 1 0 01-1.4 0L3.3 9.5a1 1 0 111.4-1.4l3.6 3.6 6.7-6.7a1 1 0 011.4 0z"/></svg>
              </span>
            )}
            {factor.right}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>