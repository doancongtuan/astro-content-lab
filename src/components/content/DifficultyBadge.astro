---
// src/components/content/DifficultyBadge.astro
interface Props {
  difficulty: 'beginner' | 'intermediate' | 'advanced'
}

const { difficulty } = Astro.props

const difficultyStyles: Record<string, { class: string; icon: string }> = {
  beginner: { class: 'bg-emerald-100 text-emerald-700', icon: '🌱' },
  intermediate: { class: 'bg-amber-100 text-amber-700', icon: '⚡' },
  advanced: { class: 'bg-red-100 text-red-700', icon: '🔥' },
}

const style = difficultyStyles[difficulty] ?? { class: 'bg-slate-100 text-slate-600', icon: '' }
---

<span class={`inline-flex items-center gap-1 mt-3 text-xs font-semibold px-2.5 py-0.5 rounded-full capitalize mb-1 ${style.class}`}>
  {style.icon && <span aria-hidden="true">{style.icon}</span>}
  {difficulty}
</span>