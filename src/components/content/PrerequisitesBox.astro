---
// src/components/content/PrerequisitesBox.astro
interface Props {
  items: string[]
  title?: string
}

const { items, title = 'Before you start' } = Astro.props
---

<div class="bg-sky-50 border border-sky-200 rounded-xl p-5 mb-8">
  <h3 class="flex items-center gap-2 text-base font-semibold text-sky-900 mb-3">
    <span aria-hidden="true">📋</span> {title}
  </h3>
  <ul class="space-y-1.5 list-none p-0 m-0">
    {items.map((item) => (
      <li class="flex items-start gap-2 text-sm text-sky-800">
        <span class="text-sky-400 mt-0.5" aria-hidden="true">•</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>