---
// src/components/content/StepBlock.astro
interface Props {
  number: number
  title: string
  isLast?: boolean
}

const { number, title, isLast = false } = Astro.props
---

<div class="relative flex gap-4 pb-8">
  {!isLast && (
    <div class="absolute left-[15px] top-8 bottom-0 w-0.5 bg-indigo-200" aria-hidden="true"></div>
  )}
  <div class="relative shrink-0 w-8 h-8 rounded-full bg-indigo-600 text-white flex items-center justify-center font-semibold text-sm z-10">
    {number}
  </div>
  <div class="flex-1 pt-0.5">
    <h3 class="text-lg font-semibold text-slate-900 mt-0 mb-2">{title}</h3>
    <div class="step-content">
      <slot />
    </div>
  </div>
</div>