---
// src/components/content/RatingStars.astro
interface Props {
  rating: number
  max?: number
  showValue?: boolean
  size?: 'sm' | 'md' | 'lg'
}

const { rating, max = 5, showValue = true, size = 'md' } = Astro.props

const sizeClasses: Record<string, string> = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
}

const starSizeClass = sizeClasses[size] ?? sizeClasses.md

const clamped = Math.max(0, Math.min(rating, max))
const uid = crypto.randomUUID().slice(0, 8)
const stars = Array.from({ length: max }, (_, i) => {
  const starPosition = i + 1
  const fillPercent = Math.max(0, Math.min(1, clamped - i)) * 100
  return { id: `star-${uid}-${i}`, fillPercent, starPosition }
})
---

<div class="inline-flex items-center gap-1.5" role="img" aria-label={`Rated ${clamped} out of ${max} stars`}>
  <div class="flex gap-0.5">
    {stars.map((star) => (
      <svg viewBox="0 0 24 24" class={`${starSizeClass} text-amber-400`} aria-hidden="true">
        <defs>
          <clipPath id={`clip-${star.id}`}>
            <rect x="0" y="0" width={`${star.fillPercent}%`} height="24" />
          </clipPath>
        </defs>
        <path
          d="M12 1.5l3.22 6.53 7.21 1.05-5.22 5.09 1.23 7.19L12 17.97l-6.44 3.39 1.23-7.19L1.57 9.08l7.21-1.05L12 1.5z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          class="text-amber-300"
        />
        <path
          d="M12 1.5l3.22 6.53 7.21 1.05-5.22 5.09 1.23 7.19L12 17.97l-6.44 3.39 1.23-7.19L1.57 9.08l7.21-1.05L12 1.5z"
          fill="currentColor"
          clip-path={`url(#clip-${star.id})`}
        />
      </svg>
    ))}
  </div>
  {showValue && (
    <span class="text-slate-600 dark:text-slate-400 text-sm">{clamped.toFixed(1)}/{max}</span>
  )}
</div>