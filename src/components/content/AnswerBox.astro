---
interface Props {
  question: string
  shortAnswer: string
}

const { question, shortAnswer } = Astro.props
---

<div class="answer-box mb-8 rounded-xl border-2 border-indigo-200 bg-indigo-50 p-6">
  <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600 mb-2">Quick Answer</p>
  <h2 class="text-lg font-bold text-slate-900 mb-2">{question}</h2>
  <p class="text-slate-700 leading-relaxed">{shortAnswer}</p>
</div>