---
interface Props {
  title: string
  url: string
}

const { title, url } = Astro.props

const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
const prompt = encodeURIComponent('Summarize this article for me: ' + url)

const shareButtons = [
  {
    label: 'X',
    href: 'https://x.com/intent/tweet?text=' + encodedTitle + '&url=' + encodedUrl,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/sharer/sharer.php?u=' + encodedUrl,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodedUrl,
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
]

const aiButtons = [
  {
    label: 'ChatGPT',
    href: 'https://chatgpt.com/?q=' + prompt,
    color: 'hover:bg-emerald-50 hover:border-emerald-400 hover:text-emerald-700',
  },
  {
    label: 'Claude',
    href: 'https://claude.ai/new?q=' + prompt,
    color: 'hover:bg-orange-50 hover:border-orange-400 hover:text-orange-700',
  },
  {
    label: 'Perplexity',
    href: 'https://www.perplexity.ai/?q=' + prompt,
    color: 'hover:bg-indigo-50 hover:border-indigo-400 hover:text-indigo-700',
  },
]
---

<div class="mt-4 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-2">
    <span class="mr-1 text-sm text-gray-500">Share:</span>

    {
      shareButtons.map((btn) => (
        <a
          href={btn.href}
          target="_blank"
          rel="noopener noreferrer"
          title={btn.label}
          aria-label={`Share on ${btn.label}`}
          class="flex h-8 w-8 items-center justify-center rounded-full border border-gray-300 text-gray-500 transition-colors duration-150 hover:border-indigo-400 hover:text-indigo-600 [&>svg]:h-4 [&>svg]:w-4"
          set:html={btn.svg}
        />
      ))
    }

    <button
      type="button"
      title="Copy link"
      aria-label="Copy link"
      id="copy-link-btn"
      data-url={url}
      class="flex h-8 w-8 items-center justify-center rounded-full border border-gray-300 text-gray-500 transition-colors duration-150 hover:border-indigo-400 hover:text-indigo-600 [&>svg]:h-4 [&>svg]:w-4"
      set:html={`<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>`}
    />
  </div>

  <div class="flex items-center gap-2">
    <span class="text-sm text-gray-500">✨ Ask AI:</span>

    {
      aiButtons.map((btn) => (
        <a
          href={btn.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`rounded-full border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-600 transition-colors duration-150 ${btn.color}`}
        >
          {btn.label}
        </a>
      ))
    }
  </div>
</div>

<script is:inline>
  ;(function () {
    var btn = document.getElementById('copy-link-btn')
    if (!btn) return

    btn.addEventListener('click', function () {
      var url = btn.getAttribute('data-url')
      if (!url || !navigator.clipboard) return

      navigator.clipboard.writeText(url).then(function () {
        btn.title = 'Copied!'
        setTimeout(function () {
          btn.title = 'Copy link'
        }, 2000)
      })
    })
  })()
</script>