---
interface Post {
  id: string
  data: {
    title: string
    description: string
    publishedAt: string | Date
    heroImage?: ImageMetadata
    heroImageCloudinary?: string
  }
}

interface Props {
  posts: Post[]
  title?: string
  basePath?: string
}

const { posts, title = 'Related Posts', basePath = '/blog/' } = Astro.props
---

{posts.length > 0 && (
  <section class="mt-12 border-t border-gray-200 pt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-6">{title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map((item) => (
        
        <a href={basePath + item.id}
          class="group block rounded-xl border border-gray-200 hover:border-indigo-300 hover:shadow-md transition-all duration-200 overflow-hidden"
        >
          {item.data.heroImage ? (
            <img
              src={item.data.heroImage.src}
              alt={item.data.title}
              class="w-full h-36 object-cover"
            />
          ) : item.data.heroImageCloudinary ? (
            <img
              src={item.data.heroImageCloudinary}
              alt={item.data.title}
              class="w-full h-36 object-cover"
            />
          ) : (
            <div class="w-full h-36 bg-gradient-to-br from-indigo-50 to-slate-100" />
          )}
          <div class="p-4">
            <h3 class="font-semibold text-gray-900 text-sm leading-snug group-hover:text-indigo-600 transition-colors line-clamp-2">
              {item.data.title}
            </h3>
            <p class="text-xs text-gray-500 mt-1 line-clamp-2">{item.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}