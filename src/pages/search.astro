---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Search — Astro Content Lab">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Search</h1>
    <p class="text-slate-500 dark:text-slate-400 mb-8">Search across all articles, reviews, guides and comparisons.</p>

    <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-slate-400 shrink-0">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-page-input"
        type="text"
        placeholder="Search articles..."
        autocomplete="off"
        autofocus
        class="flex-1 bg-transparent text-slate-900 dark:text-slate-100 placeholder-slate-400 text-sm outline-none"
      />
    </div>

    <div id="search-page-results"></div>
  </div>
</BaseLayout>

<script is:inline>
(function() {
  var pf = null;

  function loadPF(cb) {
    if (pf) { cb(); return; }
    import('/pagefind/pagefind.js').then(function(mod) {
      pf = mod;
      pf.init().then(cb);
    });
  }

  var input = document.getElementById('search-page-input');
  var results = document.getElementById('search-page-results');

  function renderResults(items, query) {
    if (!items.length) {
      results.innerHTML = '<p class="text-slate-400 dark:text-slate-500 text-sm">No results for "' + query + '"</p>';
      return;
    }
    var html = '<p class="text-sm text-slate-500 dark:text-slate-400 mb-4">' + items.length + ' results for "' + query + '"</p>';
    for (var i = 0; i < items.length; i++) {
      var r = items[i];
      html += '<a href="' + r.url + '" class="search-result-item block mb-4 p-4 rounded-xl border border-slate-200 dark:border-slate-700 no-underline hover:border-indigo-400 dark:hover:border-indigo-500 transition-colors">';
      html += '<h2 class="search-result-title text-base font-semibold mb-1">' + r.meta.title + '</h2>';
      html += '<p class="search-result-excerpt text-sm">' + r.excerpt + '</p>';
      html += '</a>';
    }
    results.innerHTML = html;
  }

  function doSearch(q) {
    if (!q) { results.innerHTML = ''; return; }
    loadPF(function() {
      pf.search(q).then(function(res) {
        Promise.all(res.results.map(function(r) { return r.data(); })).then(function(items) {
          renderResults(items, q);
        });
      });
    });
  }

  // Read query from URL on load
  var params = new URLSearchParams(window.location.search);
  var q = params.get('q') || '';
  if (q) {
    input.value = q;
    doSearch(q);
  }

  // Live search as user types
  input.addEventListener('input', function() {
    var query = input.value.trim();
    // Update URL without reload
    var url = new URL(window.location.href);
    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url);
    doSearch(query);
  });

  // Enter key
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      doSearch(input.value.trim());
    }
  });
})();
</script>