---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'

const reviews = await getCollection('reviews')
---

<BaseLayout title="Reviews — Astro Content Lab">
  <div class="page-header">
    <h1>Reviews</h1>
    <p>Honest reviews of hosting, tools and services for content sites.</p>
  </div>
  <div class="post-list">
    {reviews.map((review) => (
      <a href={`/reviews/${review.id}`} class="post-item">
        {review.data.heroImage && (
          <div class="post-thumbnail">
            <Image
              src={review.data.heroImage}
              alt={review.data.heroImageAlt || review.data.title}
              width={400}
              height={210}
            />
          </div>
        )}
        <div class="post-item-content">
          <span class="badge">Review</span>
          <h2>{review.data.title}</h2>
          <p>{review.data.description}</p>
          <p class="rating">
            {'★'.repeat(Math.floor(review.data.rating))}
            {'☆'.repeat(5 - Math.floor(review.data.rating))}
            {' '}{review.data.rating}/5
          </p>
        </div>
        <span class="post-item-link">Read review →</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { color: var(--color-text-muted); margin: 0; }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .post-item:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .post-thumbnail {
    flex-shrink: 0;
    width: 120px;
    height: 68px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .post-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-item-content {
    flex: 1;
  }

  .post-item-content h2 {
    font-size: 1rem;
    margin: 0.35rem 0;
  }

  .post-item-content p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .post-item-link {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: #ede9fe;
    color: #7c3aed;
  }

  .rating {
    color: var(--color-warning);
    margin-top: 0.35rem !important;
  }

  @media (max-width: 640px) {
    .post-item { flex-wrap: wrap; }
    .post-thumbnail { width: 100%; height: 160px; }
  }
  @media (max-width: 640px) {
  .post-item {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .post-thumbnail {
    width: 100%;
    height: 180px;
  }

  .post-item-content {
    width: 100%;
  }

  .post-item-link {
    width: 100%;
    text-align: right;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }
}
</style>