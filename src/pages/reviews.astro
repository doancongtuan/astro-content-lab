---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'

const reviews = await getCollection('reviews')
---

<BaseLayout title="Reviews — Astro Content Lab">
  <div class="mb-10 pb-6 border-b border-slate-200">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Reviews</h1>
    <p class="text-slate-500 m-0">Honest reviews of hosting, tools and services for content sites.</p>
  </div>

  <div class="flex flex-col gap-4">
    {reviews.map((review) => (
      <a href={`/reviews/${review.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 rounded-xl no-underline text-slate-900 hover:border-indigo-500 hover:shadow-sm transition-all group">
        {review.data.heroImage && (
          <div class="flex-shrink-0 w-full h-44 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            <Image
              src={review.data.heroImage}
              alt={review.data.heroImageAlt || review.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-violet-100 text-violet-700 mb-1">Review</span>
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 transition-colors">{review.data.title}</h2>
          <p class="text-sm text-slate-500 m-0">{review.data.description}</p>
          <p class="text-amber-500 text-sm mt-1 m-0">
            {'★'.repeat(Math.floor(review.data.rating))}
            {'☆'.repeat(5 - Math.floor(review.data.rating))}
            {' '}{review.data.rating}/5
          </p>
        </div>
        <span class="text-sm text-indigo-600 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read review →</span>
      </a>
    ))}
  </div>
</BaseLayout>