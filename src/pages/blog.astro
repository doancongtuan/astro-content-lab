---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'

const posts = await getCollection('posts')
---

<BaseLayout title="Blog — Astro Content Lab">
  <div class="mb-10 pb-6 border-b border-slate-200">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Blog</h1>
    <p class="text-slate-500 m-0">Thoughts, tutorials and lessons learned building with Astro.</p>
  </div>

  <div class="flex flex-col gap-4">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="flex items-center gap-4 p-4 border border-slate-200 rounded-xl no-underline text-slate-900 hover:border-indigo-500 hover:shadow-sm transition-all group">
      {(post.data.heroImage || post.data.heroImageCloudinary) && (
          <div class="flex-shrink-0 w-28 h-16 rounded-lg overflow-hidden">
            {post.data.heroImage ? (
              <Image
                src={post.data.heroImage}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                class="w-full h-full object-cover"
              />
            ) : (
              <img
                src={post.data.heroImageCloudinary}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            )}
          </div>
      )}
        <div class="flex-1 min-w-0">
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 transition-colors">{post.data.title}</h2>
          <p class="text-sm text-slate-500 m-0 line-clamp-2">{post.data.description}</p>
        </div>
        <span class="text-sm text-indigo-600 font-medium whitespace-nowrap flex-shrink-0">Read more →</span>
      </a>
    ))}
  </div>
</BaseLayout>