---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'

const allReviews = await getCollection('reviews')
const sorted = allReviews.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})

const featuredReview = sorted[0]
const restReviews = sorted.slice(1)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}

const allTags = [...new Set(sorted.flatMap(p => p.data.tags ?? []))] as string[]
---

<BaseLayout title="Reviews — Astro Content Lab">

  <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">⭐</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Reviews</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-3">Honest reviews of hosting, tools and services for content sites.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">{allReviews.length} reviews</span>
  </div>

  <!-- Tag pills -->
  <div class="mb-8 flex flex-wrap gap-2" id="tag-filter">
    {allTags.map(tag => (
      <button data-tag={tag}
        class="tag-btn text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-violet-50 dark:hover:bg-violet-950 hover:text-violet-600 dark:hover:text-violet-400 transition-all">
        #{tag}
      </button>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-16 text-slate-400 dark:text-slate-500">
    <p class="text-lg mb-2">No reviews found</p>
    <button id="clear-filter" class="text-sm text-violet-600 dark:text-violet-400 hover:underline">Clear filter</button>
  </div>

  <!-- Featured review -->
  {featuredReview && (
    <div class="mb-10 post-card"
      data-tags={JSON.stringify(featuredReview.data.tags ?? [])}>
      <a href={`/reviews/${featuredReview.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-violet-400 dark:hover:border-violet-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline">
        {featuredReview.data.heroImage && (
          <div class="overflow-hidden h-52 sm:h-64">
            <Image src={featuredReview.data.heroImage} alt={featuredReview.data.heroImageAlt || featuredReview.data.title} width={1200} height={630} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
        )}
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <CategoryBadge type="review" />
            {isNew(featuredReview.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">{featuredReview.data.title}</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-3">{featuredReview.data.description}</p>
          <div class="flex items-center gap-3">
            <span class="text-amber-500 text-sm">{'★'.repeat(Math.floor(featuredReview.data.rating))}{'☆'.repeat(5 - Math.floor(featuredReview.data.rating))} {featuredReview.data.rating}/5</span>
            <span class="text-xs text-slate-400 dark:text-slate-500">{new Date(featuredReview.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>
      </a>
    </div>
  )}

  <!-- Grid reviews -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10" id="posts-grid">
    {restReviews.map((review) => (
      <div class="post-card" data-tags={JSON.stringify(review.data.tags ?? [])}>
        <a href={`/reviews/${review.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-violet-400 dark:hover:border-violet-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full">
          <div class="overflow-hidden h-40 bg-slate-100 dark:bg-slate-700">
            {review.data.heroImage ? (
              <Image src={review.data.heroImage} alt={review.data.heroImageAlt || review.data.title} width={400} height={210} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-violet-50 to-slate-100 dark:from-violet-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              <CategoryBadge type="review" />
              {isNew(review.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h2 class="text-sm font-semibold mb-1 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors line-clamp-2">{review.data.title}</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{review.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-amber-500 text-xs">{'★'.repeat(Math.floor(review.data.rating))}{'☆'.repeat(5 - Math.floor(review.data.rating))} {review.data.rating}/5</span>
              <span class="text-xs text-violet-600 dark:text-violet-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

</BaseLayout>

<script>
  const tagBtns = document.querySelectorAll('.tag-btn')
  const cards = document.querySelectorAll('.post-card')
  const noResults = document.getElementById('no-results')
  const clearBtn = document.getElementById('clear-filter')
  let activeTag = ''

  function filterCards() {
    let visible = 0
    cards.forEach((card) => {
      const el = card as HTMLElement
      const cardTags: string[] = JSON.parse(el.dataset.tags ?? '[]')
      const match = !activeTag || cardTags.includes(activeTag)
      el.style.display = match ? '' : 'none'
      if (match) visible++
    })
    noResults!.classList.toggle('hidden', visible > 0)
    const params = new URLSearchParams()
    if (activeTag) params.set('tag', activeTag)
    history.replaceState(null, '', params.toString() ? `?${params}` : window.location.pathname)
  }

  tagBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      const tag = el.dataset.tag ?? ''
      if (activeTag === tag) {
        activeTag = ''
        el.classList.remove('bg-violet-100', 'dark:bg-violet-900', 'text-violet-600')
        el.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500')
      } else {
        activeTag = tag
        tagBtns.forEach(b => {
          b.classList.remove('bg-violet-100', 'dark:bg-violet-900', 'text-violet-600')
          b.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500')
        })
        el.classList.add('bg-violet-100', 'dark:bg-violet-900', 'text-violet-600')
        el.classList.remove('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500')
      }
      filterCards()
    })
  })

  clearBtn?.addEventListener('click', () => {
    activeTag = ''
    tagBtns.forEach(b => {
      b.classList.remove('bg-violet-100', 'dark:bg-violet-900', 'text-violet-600')
      b.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500')
    })
    filterCards()
  })

  const params = new URLSearchParams(window.location.search)
  const initTag = params.get('tag') ?? ''
  if (initTag) {
    const btn = document.querySelector(`[data-tag="${initTag}"]`) as HTMLElement
    btn?.click()
  }
</script>