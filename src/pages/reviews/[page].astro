---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'

export async function getStaticPaths() {
  const PER_PAGE = 6
  const allReviews = await getCollection('reviews')
  const sorted = allReviews.sort((a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  )
  const totalPages = Math.ceil(sorted.length / PER_PAGE)

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1
    const reviews = sorted.slice(i * PER_PAGE, page * PER_PAGE)
    return {
      params: { page: String(page) },
      props: { reviews, page, totalPages },
    }
  }).filter((p) => p.props.page > 1)
}

const { reviews, page, totalPages } = Astro.props
---

<BaseLayout title={`Reviews — Page ${page}`}>
  <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-700">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Reviews</h1>
    <p class="text-slate-500 dark:text-slate-400 m-0">Honest reviews of hosting, tools and services for content sites.</p>
  </div>

  <div class="flex flex-col gap-4">
    {reviews.map((review) => (
      <a href={`/reviews/${review.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 dark:border-slate-700 dark:bg-slate-800/50 rounded-xl no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-sm transition-all group">
        {review.data.heroImage && (
          <div class="flex-shrink-0 w-full h-44 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            <Image
              src={review.data.heroImage}
              alt={review.data.heroImageAlt || review.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300 mb-1">Review</span>
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{review.data.title}</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{review.data.description}</p>
          <p class="text-amber-500 text-sm mt-1 m-0">
            {'★'.repeat(Math.floor(review.data.rating))}
            {'☆'.repeat(5 - Math.floor(review.data.rating))}
            {' '}{review.data.rating}/5
          </p>
        </div>
        <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read review →</span>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    urlPrev={page === 2 ? '/reviews/' : `/reviews/${page - 1}/`}
    urlNext={page < totalPages ? `/reviews/${page + 1}/` : undefined}
    basePath="/reviews"
  />
</BaseLayout>