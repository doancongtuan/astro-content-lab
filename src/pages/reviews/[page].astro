---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'

export async function getStaticPaths() {
  const PER_PAGE = 6
  const allReviews = await getCollection('reviews')
  const sorted = allReviews.sort((a, b) => {
    const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
    return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
  })
  const totalPages = Math.ceil(sorted.length / PER_PAGE)

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1
    const reviews = sorted.slice(i * PER_PAGE, page * PER_PAGE)
    return {
      params: { page: String(page) },
      props: { reviews, page, totalPages },
    }
  }).filter((p) => p.props.page > 1)
}

const { reviews, page, totalPages } = Astro.props

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}
---

<BaseLayout title={`Reviews — Page ${page}`}>

  <div class="mb-10 pb-8 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">⭐</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Reviews</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-1">Honest reviews of hosting, tools and services for content sites.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">Page {page}</span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">
    {reviews.map((review) => (
      
      <a href={`/reviews/${review.id}`}
        class="fade-up group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-violet-400 dark:hover:border-violet-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
      >
        {review.data.heroImage && (
          <div class="overflow-hidden h-40">
            <Image
              src={review.data.heroImage}
              alt={review.data.heroImageAlt || review.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          </div>
        )}
        <div class="p-4 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-2">
            <CategoryBadge type="review" />
            {isNew(review.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h2 class="text-sm font-semibold mb-1 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors line-clamp-2">{review.data.title}</h2>
          <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{review.data.description}</p>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
            <span class="text-amber-500 text-xs">
              {'★'.repeat(Math.floor(review.data.rating))}{'☆'.repeat(5 - Math.floor(review.data.rating))} {review.data.rating}/5
            </span>
            <span class="text-xs text-violet-600 dark:text-violet-400 font-medium">Read →</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    urlPrev={page === 2 ? '/reviews/' : `/reviews/${page - 1}/`}
    urlNext={page < totalPages ? `/reviews/${page + 1}/` : undefined}
    basePath="/reviews"
  />

</BaseLayout>