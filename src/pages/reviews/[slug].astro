---
import { SITE_URL } from '../../config'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProjectBanner from '../../components/ProjectBanner.astro'
import SchemaOrg from '../../components/SchemaOrg.astro'
import FAQSection from '../../components/content/FAQSection.astro'
import AnswerBox from '../../components/content/AnswerBox.astro'
import RatingStars from '../../components/content/RatingStars.astro'
import ProsConsBox from '../../components/content/ProsConsBox.astro'
import VerdictBox from '../../components/content/VerdictBox.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ReadingProgress from '../../components/ReadingProgress.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import ShareButtons from '../../components/ShareButtons.astro'
import AuthorBox from '../../components/AuthorBox.astro'
import NewsletterBox from '../../components/NewsletterBox.astro'
import RelatedPosts from '../../components/RelatedPosts.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'

export async function getStaticPaths() {
  const reviews = await getCollection('reviews')
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review },
  }))
}

const { review } = Astro.props
const { Content, headings } = await render(review)

const publishedDate = new Date(review.data.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
})

const allReviews = await getCollection('reviews')
const currentTags: string[] = review.data.tags ?? []
const related = allReviews
  .filter((r) => r.id !== review.id)
  .map((r) => {
    const pTags: string[] = r.data.tags ?? []
    const tagScore = pTags.filter((t) => currentTags.includes(t)).length
    return { r, tagScore }
  })
  .sort((a, b) => b.tagScore - a.tagScore)
  .slice(0, 3)
  .map((r) => r.r)
---

<BaseLayout
  title={review.data.title}
  description={review.data.description}
  ogImage={review.data.heroImage?.src}
  ogType="article"
  narrow
>
  <SchemaOrg
    type="Review"
    title={review.data.title}
    description={review.data.description}
    publishedAt={review.data.publishedAt}
    itemReviewed={review.data.productName}
    rating={review.data.rating}
  />
  <SchemaOrg
    type="BreadcrumbList"
    items={[
      { name: 'Home', url: `${SITE_URL}/` },
      { name: 'Reviews', url: `${SITE_URL}/reviews/` },
      { name: review.data.title, url: Astro.url.href },
    ]}
  />

  <ReadingProgress />

  <article>
    <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Reviews', href: '/reviews' },
    { label: review.data.title },
  ]} />

 <div class="flex items-center gap-2 mt-4 mb-3">
  <a href="/reviews"
    class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300 no-underline hover:bg-violet-200 dark:hover:bg-violet-800 transition-colors">
    Review
  </a>
  {review.data.category && (
    <a href={`/categories/${review.data.category}`}
      class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 no-underline hover:bg-slate-200 capitalize transition-colors">
      {review.data.category}
    </a>
  )}
</div>

  <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-100 mb-3 leading-tight">{review.data.title}</h1>
  <p class="text-lg text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">{review.data.description}</p>

  <div class="flex items-center gap-3 mb-4">
    <RatingStars rating={review.data.rating} />
    <span class="text-sm text-slate-400 dark:text-slate-500">Published {publishedDate}</span>
  </div>

  {review.data.tags && review.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-5">
      {review.data.tags.map((tag: string) => (
        <a href={`/tags/${tag}`}
          class="text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 no-underline transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}

  <ShareButtons title={review.data.title} url={Astro.url.href} />
</div>

    {review.data.answerBox && (
      <AnswerBox
        question={review.data.answerBox.question}
        shortAnswer={review.data.answerBox.shortAnswer}
      />
    )}

    {review.data.heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <Image
          src={review.data.heroImage}
          alt={review.data.heroImageAlt || review.data.title}
          width={1200}
          height={630}
          class="w-full h-auto"
        />
      </div>
    )}

    {headings.length > 0 && (
      <TableOfContents headings={headings} variant="mobile" />
    )}

    <div class="lg:flex lg:gap-12 lg:items-start">
      <div class="lg:flex-1 min-w-0">
        <ProsConsBox pros={review.data.pros} cons={review.data.cons} />
        <VerdictBox verdict={review.data.verdict} rating={review.data.rating} />
        <div class="post-body prose">
          <Content />
        </div>
        {review.data.faq && <FAQSection items={review.data.faq} />}
        <AuthorBox />
        <NewsletterBox />
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-56 shrink-0 sticky top-24 self-start">
          <TableOfContents headings={headings} variant="desktop" />
        </aside>
      )}
    </div>

    <RelatedPosts posts={related} title="More Reviews" basePath="/reviews/" />

  </article>

  <ProjectBanner />
</BaseLayout>