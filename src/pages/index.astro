---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { AUTHOR } from '../config'

const posts = await getCollection('posts')
const reviews = await getCollection('reviews')
const guides = await getCollection('guides')
const compares = await getCollection('compares')

const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)

const featuredPost = sortedPosts[0]
const latestPosts = sortedPosts.slice(1, 4)
const latestReviews = reviews.slice(0, 2)

function readingTime(content: string) {
  const words = content?.split(/\s+/).length ?? 0
  return Math.max(1, Math.round(words / 200))
}
---

<BaseLayout title="Astro Content Lab — Learn Astro from Scratch">

  <!-- Hero -->
  <section class="relative py-20 mb-12 overflow-hidden">
    <!-- Dot pattern background -->
    <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.06]"
      style="background-image: radial-gradient(circle, #4f46e5 1px, transparent 1px); background-size: 24px 24px;">
    </div>

    <div class="relative text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-50 dark:bg-indigo-950 border border-indigo-200 dark:border-indigo-800 text-indigo-600 dark:text-indigo-400 text-xs font-semibold mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
        Built in public · Series ongoing
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold max-w-2xl mx-auto mb-4 leading-tight">
        <span class="text-slate-900 dark:text-slate-100">You know WordPress.</span>
        <br />
        <span class="bg-gradient-to-r from-indigo-600 to-emerald-500 bg-clip-text text-transparent">
          Here is Astro.
        </span>
      </h1>

      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mx-auto mb-8">
        A hands-on series documenting the real transition — from WordPress sites to modern static stack. Every article is a real lesson from a real project.
      </p>

      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/blog" class="inline-block px-5 py-2.5 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors no-underline">
          Start Reading →
        </a>
        <a href="/about" class="inline-block px-5 py-2.5 border border-slate-200 dark:border-slate-600 text-slate-900 dark:text-slate-100 font-semibold rounded-lg hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline">
          About this project
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-14 py-6 border-y border-slate-200 dark:border-slate-700">
    {[
      { label: 'Blog posts', value: posts.length },
      { label: 'Reviews', value: reviews.length },
      { label: 'Guides', value: guides.length },
      { label: 'Comparisons', value: compares.length },
    ].map((stat) => (
      <div class="text-center">
        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{stat.value}</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">{stat.label}</p>
      </div>
    ))}
  </section>

  <!-- Featured post -->
  {featuredPost && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Featured</h2>
      </div>
      
      <a  href={`/blog/${featuredPost.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-indigo-400 dark:hover:border-indigo-500 hover:shadow-lg transition-all duration-300 no-underline hover:-translate-y-1"
      >
        {(featuredPost.data.heroImage || featuredPost.data.heroImageCloudinary) && (
          <div class="overflow-hidden h-56 sm:h-72">
            {featuredPost.data.heroImage ? (
              <img
                src={featuredPost.data.heroImage.src}
                alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <img
                src={featuredPost.data.heroImageCloudinary}
                alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            )}
          </div>
        )}
        <div class="p-6">
          <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 mb-3">Latest</span>
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
            {featuredPost.data.title}
          </h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-4">
            {featuredPost.data.description}
          </p>
          <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Read article →</span>
        </div>
      </a>
    </section>
  )}

  <!-- Latest Posts -->
  <section class="mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Latest Posts</h2>
      <a href="/blog" class="text-sm text-indigo-600 dark:text-indigo-400 font-medium hover:underline">See all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {latestPosts.map((post) => (
        
        <a href={`/blog/${post.id}`}
          class="group flex flex-col justify-between border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl p-5 no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
        >
          <div>
            <h3 class="text-base font-semibold mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{post.data.title}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{post.data.description}</p>
          </div>
          <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium mt-4 block">Read more →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Reviews -->
  <section class="mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Latest Reviews</h2>
      <a href="/reviews" class="text-sm text-indigo-600 dark:text-indigo-400 font-medium hover:underline">See all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {latestReviews.map((review) => (
        
        <a href={`/reviews/${review.id}`}
          class="group flex flex-col justify-between border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl p-5 no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
        >
          <div>
            <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300 mb-2">Review</span>
            <h3 class="text-base font-semibold mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{review.data.title}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{review.data.description}</p>
            <p class="text-amber-500 text-sm mt-2 m-0">
              {'★'.repeat(Math.floor(review.data.rating))}{'☆'.repeat(5 - Math.floor(review.data.rating))} {review.data.rating}/5
            </p>
          </div>
          <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium mt-4 block">Read review →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Author strip -->
  <section class="flex items-center gap-4 p-6 rounded-2xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 mb-4">
    {AUTHOR.avatar ? (
      <img src={AUTHOR.avatar} alt={AUTHOR.name} class="w-14 h-14 rounded-full object-cover shrink-0" />
    ) : (
      <div class="w-14 h-14 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center shrink-0">
        <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400">{AUTHOR.name.charAt(0)}</span>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <p class="font-bold text-slate-900 dark:text-slate-100 mb-0.5">{AUTHOR.name}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{AUTHOR.bio}</p>
    </div>
    <a href="/about" class="shrink-0 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline whitespace-nowrap">
      About →
    </a>
  </section>

</BaseLayout>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-up {
    animation: fadeUp 0.5s ease forwards;
  }
</style>