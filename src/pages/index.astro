---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import { AUTHOR } from '../config'

const posts = await getCollection('posts')
const reviews = await getCollection('reviews')
const guides = await getCollection('guides')
const compares = await getCollection('compares')

const sortedPosts = posts.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})

const sortedReviews = reviews.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)

const featuredPost = sortedPosts[0]
const latestPosts = sortedPosts.slice(1, 7)
const latestReviews = sortedReviews.slice(0, 2)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}
---

<BaseLayout title="Astro Content Lab — Learn Astro from Scratch" fullBleedHero>

  <!-- Hero full bleed -->
  <section slot="hero" class="relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 20% 40%, #4f46e5 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 80% 20%, #7c3aed 0%, transparent 55%), radial-gradient(ellipse 70% 50% at 60% 80%, #059669 0%, transparent 55%), radial-gradient(ellipse 90% 90% at 50% 50%, #0f172a 0%, #0f172a 100%);"></div>

    <div class="relative max-w-5xl mx-auto px-5">
      <div class="text-center max-w-3xl mx-auto pt-12 pb-8 sm:pt-24 sm:pb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white/80 text-xs font-semibold mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Built in public · Series ongoing
        </div>
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold mb-4 sm:mb-6 leading-tight tracking-tight">
          <span class="text-white">You know WordPress.</span>
          <br />
          <span class="bg-gradient-to-r from-indigo-300 via-violet-300 to-emerald-300 bg-clip-text text-transparent">
            Here is Astro.
          </span>
        </h1>
        <p class="text-lg text-white/60 max-w-xl mx-auto mb-10 leading-relaxed">
          A hands-on series documenting the real transition — from WordPress sites to modern static stack. Every article is a real lesson from a real project.
        </p>
        <div class="flex gap-3 justify-center flex-wrap">
          <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors no-underline text-sm">
            Start Reading →
          </a>
          <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors no-underline text-sm">
            About this project
          </a>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="grid grid-cols-2 sm:grid-cols-4 border-t border-white/10 pb-10">
        {[
          { label: 'Blog posts', value: posts.length, href: '/blog' },
          { label: 'Reviews', value: reviews.length, href: '/reviews' },
          { label: 'Guides', value: guides.length, href: '/guides' },
          { label: 'Comparisons', value: compares.length, href: '/compares' },
        ].map((stat) => (
          <a href={stat.href} class="text-center no-underline group py-6">
            <p class="text-3xl font-bold text-white group-hover:text-emerald-300 transition-colors">{stat.value}</p>
            <p class="text-sm text-white/50">{stat.label}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Reviews -->
  <section class="fade-up mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Latest Reviews</h2>
      <a href="/reviews" class="text-sm text-indigo-600 dark:text-indigo-400 font-medium hover:underline">See all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {latestReviews.map((review) => (
        <a href={`/reviews/${review.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-violet-400 dark:hover:border-violet-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          
          <div class="overflow-hidden h-40 bg-slate-100 dark:bg-slate-700">
            {review.data.heroImage ? (
              <img
                src={review.data.heroImage.src}
                alt={review.data.heroImageAlt || review.data.title}
                width={600}
                height={300}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-violet-50 to-slate-100 dark:from-violet-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300">Review</span>
              {isNew(review.data.publishedAt) && (
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h3 class="text-sm font-semibold mb-1 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors line-clamp-2">{review.data.title}</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{review.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-amber-500 text-xs">
                {'★'.repeat(Math.floor(review.data.rating))}{'☆'.repeat(5 - Math.floor(review.data.rating))} {review.data.rating}/5
              </span>
              <span class="text-xs text-violet-600 dark:text-violet-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured post -->
  {featuredPost && (
    <section class="fade-up mb-14">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Featured</h2>
      </div>
      <a href={`/blog/${featuredPost.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-indigo-400 dark:hover:border-indigo-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline">
        <div class="overflow-hidden h-56 sm:h-72 bg-slate-100 dark:bg-slate-700">
          {featuredPost.data.heroImage ? (
            <img src={featuredPost.data.heroImage.src} alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          ) : featuredPost.data.heroImageCloudinary ? (
            <img src={featuredPost.data.heroImageCloudinary} alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          ) : (
            <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-slate-100 dark:from-indigo-950 dark:to-slate-800" />
          )}
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300">Latest</span>
            {isNew(featuredPost.data.publishedAt) && (
              <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{featuredPost.data.title}</h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-4">{featuredPost.data.description}</p>
          <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Read article →</span>
        </div>
      </a>
    </section>
  )}

  <!-- Latest Posts -->
  <section class="fade-up mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Latest Posts</h2>
      <a href="/blog" class="text-sm text-indigo-600 dark:text-indigo-400 font-medium hover:underline">See all →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="overflow-hidden h-36 bg-slate-100 dark:bg-slate-700">
            {post.data.heroImage ? (
              <img src={post.data.heroImage.src} alt={post.data.heroImageAlt || post.data.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : post.data.heroImageCloudinary ? (
              <img src={post.data.heroImageCloudinary} alt={post.data.heroImageAlt || post.data.title}
                loading="lazy" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-slate-100 dark:from-indigo-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              {isNew(post.data.publishedAt) && (
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
              {post.data.tags?.slice(0, 1).map((tag: string) => (
                <span class="text-xs text-slate-400 dark:text-slate-500">#{tag}</span>
              ))}
            </div>
            <h3 class="text-sm font-semibold mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors line-clamp-2">{post.data.title}</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{post.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-xs text-slate-400 dark:text-slate-500">
                {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
              <span class="text-xs text-indigo-600 dark:text-indigo-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Author strip -->
  <section class="fade-up flex items-center gap-4 p-6 rounded-2xl bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 mb-4">
    {AUTHOR.avatar ? (
      <img src={AUTHOR.avatar} alt={AUTHOR.name} class="w-14 h-14 rounded-full object-cover shrink-0" />
    ) : (
      <div class="w-14 h-14 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center shrink-0">
        <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400">{AUTHOR.name.charAt(0)}</span>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <p class="font-bold text-slate-900 dark:text-slate-100 mb-0.5">{AUTHOR.name}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{AUTHOR.bio}</p>
    </div>
    <a href="/about" class="shrink-0 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline no-underline whitespace-nowrap">
      About →
    </a>
  </section>

</BaseLayout>