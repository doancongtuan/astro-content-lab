---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="404 — Page Not Found">
  <div class="flex flex-col items-center justify-center text-center py-24">
    <p class="text-8xl font-bold bg-gradient-to-r from-indigo-600 to-emerald-500 bg-clip-text text-transparent mb-4">404</p>
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-3">Page not found</h1>
    <p class="text-slate-500 dark:text-slate-400 max-w-md mb-8">
      This page doesn't exist or was moved. Happens to the best of us.
    </p>
    <div class="flex gap-3 flex-wrap justify-center">
      <a href="/" class="inline-block px-5 py-2.5 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors no-underline">
        Go home
      </a>
      <a href="/blog" class="inline-block px-5 py-2.5 border border-slate-200 dark:border-slate-600 text-slate-900 dark:text-slate-100 font-semibold rounded-lg hover:border-indigo-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors no-underline">
        Read the blog
      </a>
    </div>
  </div>
</BaseLayout>