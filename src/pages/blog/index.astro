---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allPosts = await getCollection('posts')
const sorted = allPosts.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})

const featuredPost = sorted[0]
const restPosts = sorted.slice(1)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}

// Get all unique categories and tags
const allCategories = [...new Set(sorted.map(p => p.data.category).filter(Boolean))] as string[]
const allTags = [...new Set(sorted.flatMap(p => p.data.tags ?? []))] as string[]
---

<BaseLayout title="Blog — Astro Content Lab">

  <!-- Hero -->
  <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">📝</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Blog</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-3">Thoughts, tutorials and lessons learned building with Astro.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">{allPosts.length} articles</span>
  </div>

  <!-- Category tabs -->
  <div class="mb-4 flex flex-wrap gap-2" id="category-filter">
    <button
      data-category=""
      class="category-btn active-cat text-xs font-semibold px-3 py-1.5 rounded-full border border-indigo-500 bg-indigo-500 text-white transition-all">
      All
    </button>
    {allCategories.map(cat => (
      <button
        data-category={cat}
        class="category-btn text-xs font-semibold px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all capitalize">
        {cat}
      </button>
    ))}
  </div>

  <!-- Tag pills -->
  <div class="mb-8 flex flex-wrap gap-2" id="tag-filter">
    {allTags.map(tag => (
      <button
        data-tag={tag}
        class="tag-btn text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all">
        #{tag}
      </button>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-16 text-slate-400 dark:text-slate-500">
    <p class="text-lg mb-2">No articles found</p>
    <button id="clear-filter" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">Clear filter</button>
  </div>

  <!-- Featured post -->
  <div id="featured-wrapper">
    {featuredPost && (
      <div
        class="mb-10 fade-up post-card"
        data-category={featuredPost.data.category ?? ''}
        data-tags={JSON.stringify(featuredPost.data.tags ?? [])}
      >
        
        <a href={`/blog/${featuredPost.id}`}
          class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-indigo-400 dark:hover:border-indigo-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline"
        >
          {(featuredPost.data.heroImage || featuredPost.data.heroImageCloudinary) && (
            <div class="overflow-hidden h-52 sm:h-64">
              {featuredPost.data.heroImage ? (
                <Image
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                  width={1200}
                  height={630}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              ) : (
                <img
                  src={featuredPost.data.heroImageCloudinary}
                  alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              )}
            </div>
          )}
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300">Latest</span>
              {isNew(featuredPost.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
              {featuredPost.data.title}
            </h2>
            <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-3">{featuredPost.data.description}</p>
            <span class="text-xs text-slate-400 dark:text-slate-500">
              {new Date(featuredPost.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
        </a>
      </div>
    )}
  </div>

  <!-- Grid posts -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10" id="posts-grid">
    {restPosts.map((post) => (
      <div
        class="post-card"
        data-category={post.data.category ?? ''}
        data-tags={JSON.stringify(post.data.tags ?? [])}
      >
        
        <a  href={`/blog/${post.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full"
        >
          <div class="overflow-hidden h-36 bg-slate-100 dark:bg-slate-700">
            {post.data.heroImage ? (
              <Image
                src={post.data.heroImage}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : post.data.heroImageCloudinary ? (
              <img
                src={post.data.heroImageCloudinary}
                alt={post.data.heroImageAlt || post.data.title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-slate-100 dark:from-indigo-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              {isNew(post.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
              {post.data.tags?.slice(0, 1).map((tag: string) => (
                <span class="text-xs text-slate-400 dark:text-slate-500">#{tag}</span>
              ))}
            </div>
            <h2 class="text-sm font-semibold mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors line-clamp-2">{post.data.title}</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{post.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-xs text-slate-400 dark:text-slate-500">
                {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
              <span class="text-xs text-indigo-600 dark:text-indigo-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

</BaseLayout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn')
  const tagBtns = document.querySelectorAll('.tag-btn')
  const cards = document.querySelectorAll('.post-card')
  const noResults = document.getElementById('no-results')
  const clearBtn = document.getElementById('clear-filter')

  let activeCategory = ''
  let activeTag = ''

  function filterCards() {
    let visible = 0

    cards.forEach((card) => {
      const el = card as HTMLElement
      const cardCategory = el.dataset.category ?? ''
      const cardTags: string[] = JSON.parse(el.dataset.tags ?? '[]')

      const matchCat = !activeCategory || cardCategory === activeCategory
      const matchTag = !activeTag || cardTags.includes(activeTag)

      if (matchCat && matchTag) {
        el.style.display = ''
        visible++
      } else {
        el.style.display = 'none'
      }
    })

    noResults!.classList.toggle('hidden', visible > 0)

    // Update URL
    const params = new URLSearchParams()
    if (activeCategory) params.set('category', activeCategory)
    if (activeTag) params.set('tag', activeTag)
    const newUrl = params.toString() ? `?${params}` : window.location.pathname
    history.replaceState(null, '', newUrl)
  }

  categoryBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      activeCategory = el.dataset.category ?? ''

      categoryBtns.forEach(b => {
        b.classList.remove('active-cat', 'bg-indigo-500', 'border-indigo-500', 'text-white')
        b.classList.add('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')
      })
      el.classList.add('active-cat', 'bg-indigo-500', 'border-indigo-500', 'text-white')
      el.classList.remove('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')

      filterCards()
    })
  })

  tagBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      const tag = el.dataset.tag ?? ''

      if (activeTag === tag) {
        activeTag = ''
        el.classList.remove('bg-indigo-100', 'dark:bg-indigo-900', 'text-indigo-600', 'dark:text-indigo-400')
        el.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400')
      } else {
        activeTag = tag
        tagBtns.forEach(b => {
          b.classList.remove('bg-indigo-100', 'dark:bg-indigo-900', 'text-indigo-600', 'dark:text-indigo-400')
          b.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400')
        })
        el.classList.add('bg-indigo-100', 'dark:bg-indigo-900', 'text-indigo-600', 'dark:text-indigo-400')
        el.classList.remove('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400')
      }

      filterCards()
    })
  })

  clearBtn?.addEventListener('click', () => {
    activeCategory = ''
    activeTag = ''

    categoryBtns.forEach(b => {
      b.classList.remove('active-cat', 'bg-indigo-500', 'border-indigo-500', 'text-white')
      b.classList.add('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')
    })
    const allBtn = document.querySelector('[data-category=""]') as HTMLElement
    allBtn?.classList.add('active-cat', 'bg-indigo-500', 'border-indigo-500', 'text-white')
    allBtn?.classList.remove('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')

    tagBtns.forEach(b => {
      b.classList.remove('bg-indigo-100', 'dark:bg-indigo-900', 'text-indigo-600', 'dark:text-indigo-400')
      b.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400')
    })

    filterCards()
  })

  // Restore from URL on load
  const params = new URLSearchParams(window.location.search)
  const initCat = params.get('category') ?? ''
  const initTag = params.get('tag') ?? ''

  if (initCat) {
    const btn = document.querySelector(`[data-category="${initCat}"]`) as HTMLElement
    btn?.click()
  }
  if (initTag) {
    const btn = document.querySelector(`[data-tag="${initTag}"]`) as HTMLElement
    btn?.click()
  }
</script>