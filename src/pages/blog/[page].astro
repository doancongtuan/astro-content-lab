---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'

export async function getStaticPaths() {
  const PER_PAGE = 6
  const allPosts = await getCollection('posts')
  const sorted = allPosts.sort((a, b) => {
    const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
    return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
  })
  const totalPages = Math.ceil(sorted.length / PER_PAGE)

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1
    const posts = sorted.slice(i * PER_PAGE, page * PER_PAGE)
    return {
      params: { page: String(page) },
      props: { posts, page, totalPages },
    }
  }).filter((p) => p.props.page > 1)
}

const { posts, page, totalPages } = Astro.props

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}
---

<BaseLayout title={`Blog — Page ${page}`}>

  <div class="mb-10 pb-8 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">📝</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Blog</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-1">Thoughts, tutorials and lessons learned building with Astro.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">Page {page}</span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
    {posts.map((post) => (
      
      <a href={`/blog/${post.id}`}
        class="fade-up group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
      >
        {(post.data.heroImage || post.data.heroImageCloudinary) && (
          <div class="overflow-hidden h-36">
            {post.data.heroImage ? (
              <Image
                src={post.data.heroImage}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            ) : (
              <img
                src={post.data.heroImageCloudinary}
                alt={post.data.heroImageAlt || post.data.title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            )}
          </div>
        )}
        <div class="p-4 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-2">
            {isNew(post.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
            {post.data.tags?.slice(0, 1).map((tag: string) => (
              <span class="text-xs text-slate-400 dark:text-slate-500">#{tag}</span>
            ))}
          </div>
          <h2 class="text-sm font-semibold mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors line-clamp-2">{post.data.title}</h2>
          <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{post.data.description}</p>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
            <span class="text-xs text-slate-400 dark:text-slate-500">
              {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
            <span class="text-xs text-indigo-600 dark:text-indigo-400 font-medium">Read →</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    urlPrev={page === 2 ? '/blog/' : `/blog/${page - 1}/`}
    urlNext={page < totalPages ? `/blog/${page + 1}/` : undefined}
    basePath="/blog"
  />

</BaseLayout>