---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'

export async function getStaticPaths() {
  const PER_PAGE = 6
  const allPosts = await getCollection('posts')
  const sorted = allPosts.sort((a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  )

  const totalPages = Math.ceil(sorted.length / PER_PAGE)

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1
    const posts = sorted.slice(i * PER_PAGE, page * PER_PAGE)
    return {
      params: { page: String(page) },
      props: { posts, page, totalPages },
    }
  }).filter((p) => p.props.page > 1)
}

const { posts, page, totalPages } = Astro.props
---

<BaseLayout title={`Blog — Page ${page}`}>
  <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-700">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Blog</h1>
    <p class="text-slate-500 dark:text-slate-400 m-0">Thoughts, tutorials and lessons learned building with Astro.</p>
  </div>

  <div class="flex flex-col gap-4">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 dark:border-slate-700 dark:bg-slate-800/50 rounded-xl no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-sm transition-all group">
        {(post.data.heroImage || post.data.heroImageCloudinary) && (
          <div class="flex-shrink-0 w-full h-40 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            {post.data.heroImage ? (
              <Image
                src={post.data.heroImage}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                class="w-full h-full object-cover"
              />
            ) : (
              <img
                src={post.data.heroImageCloudinary}
                alt={post.data.heroImageAlt || post.data.title}
                width={400}
                height={210}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            )}
          </div>
        )}
        <div class="flex-1 min-w-0">
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{post.data.title}</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 m-0 line-clamp-2">{post.data.description}</p>
        </div>
        <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read more →</span>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={page}
    lastPage={totalPages}
    urlPrev={page === 2 ? '/blog/' : `/blog/${page - 1}/`}
    urlNext={page < totalPages ? `/blog/${page + 1}/` : undefined}
    basePath="/blog"
  />
</BaseLayout>