---
import { SITE_URL } from '../../config'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProjectBanner from '../../components/ProjectBanner.astro'
import SchemaOrg from '../../components/SchemaOrg.astro'
import FAQSection from '../../components/content/FAQSection.astro'
import AnswerBox from '../../components/content/AnswerBox.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ReadingProgress from '../../components/ReadingProgress.astro'
import RelatedPosts from '../../components/RelatedPosts.astro'
import AuthorBox from '../../components/AuthorBox.astro'
import ShareButtons from '../../components/ShareButtons.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import NewsletterBox from '../../components/NewsletterBox.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const publishedDate = new Date(post.data.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
})

const allPosts = await getCollection('posts')
const currentTags: string[] = post.data.tags ?? []
const related = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const pTags: string[] = p.data.tags ?? []
    const tagScore = pTags.filter((t) => currentTags.includes(t)).length
    return { p, tagScore }
  })
  .sort((a, b) => b.tagScore - a.tagScore)
  .slice(0, 3)
  .map((r) => r.p)
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage?.src ?? post.data.heroImageCloudinary}
  ogType="article"
  narrow
>
  <SchemaOrg
    type="Article"
    title={post.data.title}
    description={post.data.description}
    publishedAt={post.data.publishedAt}
  />
  <SchemaOrg
    type="BreadcrumbList"
    items={[
      { name: 'Home', url: `${SITE_URL}/` },
      { name: 'Blog', url: `${SITE_URL}/blog/` },
      { name: post.data.title, url: Astro.url.href },
    ]}
  />

  <ReadingProgress />

  <article>
  
  <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
  <Breadcrumb items={[
    { label: 'Home', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: post.data.title },
  ]} />

  <div class="flex items-center gap-2 mt-4 mb-3">
    <a href="/blog"
      class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 no-underline hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors">
      Blog
    </a>
    {post.data.category && (
      <a href={`/categories/${post.data.category}`}
        class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 no-underline hover:bg-slate-200 dark:hover:bg-slate-700 capitalize transition-colors">
        {post.data.category}
      </a>
    )}
  </div>

  <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-100 mb-3 leading-tight">{post.data.title}</h1>
  <p class="text-lg text-slate-500 dark:text-slate-400 mb-4 leading-relaxed">{post.data.description}</p>

  <div class="flex items-center gap-2 text-sm text-slate-400 dark:text-slate-500 mb-4">
    <span>Published {publishedDate}</span>
  </div>

  {post.data.tags && post.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-5">
      {post.data.tags.map((tag: string) => (
        <a href={`/tags/${tag}`}
          class="text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 no-underline transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}

  <ShareButtons title={post.data.title} url={Astro.url.href} />
</div>

    {post.data.answerBox && (
      <AnswerBox
        question={post.data.answerBox.question}
        shortAnswer={post.data.answerBox.shortAnswer}
      />
    )}

    {post.data.heroImage ? (
      <div class="mb-8 rounded-xl overflow-hidden">
        <Image
          src={post.data.heroImage}
          alt={post.data.heroImageAlt || post.data.title}
          width={1200}
          height={630}
          class="w-full h-auto"
        />
      </div>
    ) : post.data.heroImageCloudinary ? (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img
          src={post.data.heroImageCloudinary}
          alt={post.data.heroImageAlt || post.data.title}
          width={1200}
          height={630}
          loading="lazy"
          class="w-full h-auto"
        />
      </div>
    ) : null}

    {headings.length > 0 && (
      <TableOfContents headings={headings} variant="mobile" />
    )}

    <div class="lg:flex lg:gap-12 lg:items-start">
      <div class="lg:flex-1 min-w-0">
        <div class="post-body prose">
          <Content />
        </div>
        {post.data.faq && <FAQSection items={post.data.faq} />}
       
       <ShareButtons title={post.data.title} url={Astro.url.href} />
       <AuthorBox />
       <NewsletterBox />
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-56 shrink-0 sticky top-24 self-start">
          <TableOfContents headings={headings} variant="desktop" />
        </aside>
      )}
    </div>

    <RelatedPosts posts={related} />

  </article>

  <ProjectBanner />
</BaseLayout>