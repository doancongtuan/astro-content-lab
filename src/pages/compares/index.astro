---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'

const PER_PAGE = 6
const allCompares = await getCollection('compares')
const sorted = allCompares.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)
const totalPages = Math.ceil(sorted.length / PER_PAGE)
const compares = sorted.slice(0, PER_PAGE)
---

<BaseLayout title="Comparisons — Astro Content Lab">
  <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-700">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Comparisons</h1>
    <p class="text-slate-500 dark:text-slate-400 m-0">Side-by-side comparisons to help you pick the right tool.</p>
  </div>

  <div class="flex flex-col gap-4">
    {compares.map((compare) => (
      <a href={`/compares/${compare.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 dark:border-slate-700 dark:bg-slate-800/50 rounded-xl no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-sm transition-all group">
        {compare.data.heroImage && (
          <div class="flex-shrink-0 w-full h-44 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            <Image
              src={compare.data.heroImage}
              alt={compare.data.heroImageAlt || compare.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <CategoryBadge type="compare" />
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{compare.data.title}</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{compare.data.description}</p>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 m-0">🏆 Winner: {compare.data.winner}</p>
        </div>
        <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read comparison →</span>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={1}
    lastPage={totalPages}
    urlPrev={undefined}
    urlNext={totalPages > 1 ? '/compares/2/' : undefined}
    basePath="/compares"
  />
</BaseLayout>