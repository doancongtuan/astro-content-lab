---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'

const allCompares = await getCollection('compares')
const sorted = allCompares.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})

const featuredCompare = sorted[0]
const restCompares = sorted.slice(1)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}

const allTags = [...new Set(sorted.flatMap(p => p.data.tags ?? []))] as string[]
---

<BaseLayout title="Comparisons — Astro Content Lab">

  <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">⚡</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Comparisons</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-3">Side-by-side comparisons to help you pick the right tool.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">{allCompares.length} comparisons</span>
  </div>

  <!-- Tag pills -->
  <div class="mb-8 flex flex-wrap gap-2">
    {allTags.map(tag => (
      <button data-tag={tag}
        class="tag-btn text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-sky-50 dark:hover:bg-sky-950 hover:text-sky-600 dark:hover:text-sky-400 transition-all">
        #{tag}
      </button>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-16 text-slate-400 dark:text-slate-500">
    <p class="text-lg mb-2">No comparisons found</p>
    <button id="clear-filter" class="text-sm text-sky-600 dark:text-sky-400 hover:underline">Clear filter</button>
  </div>

  <!-- Featured compare -->
  {featuredCompare && (
    <div class="mb-10 post-card" data-tags={JSON.stringify(featuredCompare.data.tags ?? [])}>
      <a href={`/compares/${featuredCompare.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-sky-400 dark:hover:border-sky-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline">
        {featuredCompare.data.heroImage && (
          <div class="overflow-hidden h-52 sm:h-64">
            <Image src={featuredCompare.data.heroImage} alt={featuredCompare.data.heroImageAlt || featuredCompare.data.title} width={1200} height={630} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
        )}
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <CategoryBadge type="compare" />
            {isNew(featuredCompare.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors">{featuredCompare.data.title}</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-3">{featuredCompare.data.description}</p>
          <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500">
            <span>🏆 Winner: {featuredCompare.data.winner}</span>
            <span>·</span>
            <span>{new Date(featuredCompare.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>
      </a>
    </div>
  )}

  <!-- Grid compares -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">
    {restCompares.map((compare) => (
      <div class="post-card" data-tags={JSON.stringify(compare.data.tags ?? [])}>
        <a href={`/compares/${compare.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-sky-400 dark:hover:border-sky-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full">
          <div class="overflow-hidden h-40 bg-slate-100 dark:bg-slate-700">
            {compare.data.heroImage ? (
              <Image src={compare.data.heroImage} alt={compare.data.heroImageAlt || compare.data.title} width={400} height={210} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-sky-50 to-slate-100 dark:from-sky-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              <CategoryBadge type="compare" />
              {isNew(compare.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h2 class="text-sm font-semibold mb-1 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors line-clamp-2">{compare.data.title}</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{compare.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-xs text-slate-400 dark:text-slate-500">🏆 {compare.data.winner}</span>
              <span class="text-xs text-sky-600 dark:text-sky-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

</BaseLayout>

<script>
  const tagBtns = document.querySelectorAll('.tag-btn')
  const cards = document.querySelectorAll('.post-card')
  const noResults = document.getElementById('no-results')
  const clearBtn = document.getElementById('clear-filter')
  let activeTag = ''

  function filterCards() {
    let visible = 0
    cards.forEach((card) => {
      const el = card as HTMLElement
      const cardTags: string[] = JSON.parse(el.dataset.tags ?? '[]')
      const match = !activeTag || cardTags.includes(activeTag)
      el.style.display = match ? '' : 'none'
      if (match) visible++
    })
    noResults!.classList.toggle('hidden', visible > 0)
  }

  tagBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      const tag = el.dataset.tag ?? ''
      if (activeTag === tag) {
        activeTag = ''
        el.classList.remove('bg-sky-100', 'text-sky-600')
        el.classList.add('bg-slate-100', 'text-slate-500')
      } else {
        activeTag = tag
        tagBtns.forEach(b => {
          b.classList.remove('bg-sky-100', 'text-sky-600')
          b.classList.add('bg-slate-100', 'text-slate-500')
        })
        el.classList.add('bg-sky-100', 'text-sky-600')
        el.classList.remove('bg-slate-100', 'text-slate-500')
      }
      filterCards()
    })
  })

  clearBtn?.addEventListener('click', () => {
    activeTag = ''
    tagBtns.forEach(b => {
      b.classList.remove('bg-sky-100', 'text-sky-600')
      b.classList.add('bg-slate-100', 'text-slate-500')
    })
    filterCards()
  })
</script>