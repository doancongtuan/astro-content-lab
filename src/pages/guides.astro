---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'

const guides = await getCollection('guides')

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-100 text-emerald-700',
  intermediate: 'bg-amber-100 text-amber-700',
  advanced: 'bg-red-100 text-red-700',
}
---

<BaseLayout title="Guides — Astro Content Lab">
  <div class="mb-10 pb-6 border-b border-slate-200">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Guides</h1>
    <p class="text-slate-500 m-0">Step-by-step guides for building with Astro.</p>
  </div>

  <div class="flex flex-col gap-4">
    {guides.map((guide) => (
      <a href={`/guides/${guide.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 rounded-xl no-underline text-slate-900 hover:border-indigo-500 hover:shadow-sm transition-all group">
        {guide.data.heroImage && (
          <div class="flex-shrink-0 w-full h-44 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            <Image
              src={guide.data.heroImage}
              alt={guide.data.heroImageAlt || guide.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mb-1 capitalize ${difficultyColors[guide.data.difficulty] ?? 'bg-slate-100 text-slate-600'}`}>
            {guide.data.difficulty}
          </span>
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 transition-colors">{guide.data.title}</h2>
          <p class="text-sm text-slate-500 m-0">{guide.data.description}</p>
          <p class="text-sm text-slate-400 mt-1 m-0">⏱ {guide.data.estimatedTime}</p>
        </div>
       <span class="text-sm text-indigo-600 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read guide →</span>
      </a>
    ))}
  </div>
</BaseLayout>