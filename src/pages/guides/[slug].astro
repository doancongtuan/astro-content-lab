---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const guides = await getCollection('guides')
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }))
}

const { guide } = Astro.props
const { Content } = await render(guide)
---

<BaseLayout title={guide.data.title}>
  <h1>{guide.data.title}</h1>
  <p>{guide.data.description}</p>
  <p>Difficulty: {guide.data.difficulty}</p>
  <p>Estimated time: {guide.data.estimatedTime}</p>
  <Content />
</BaseLayout>