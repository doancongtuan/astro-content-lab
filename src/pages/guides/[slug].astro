---
import { SITE_URL } from '../../config'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProjectBanner from '../../components/ProjectBanner.astro'
import SchemaOrg from '../../components/SchemaOrg.astro'
import FAQSection from '../../components/content/FAQSection.astro'
import AnswerBox from '../../components/content/AnswerBox.astro'
import DifficultyBadge from '../../components/content/DifficultyBadge.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ReadingProgress from '../../components/ReadingProgress.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import ShareButtons from '../../components/ShareButtons.astro'
import AuthorBox from '../../components/AuthorBox.astro'
import NewsletterBox from '../../components/NewsletterBox.astro'
import RelatedPosts from '../../components/RelatedPosts.astro'

export async function getStaticPaths() {
  const guides = await getCollection('guides')
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }))
}

const { guide } = Astro.props
const { Content, headings } = await render(guide)

const publishedDate = new Date(guide.data.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
})

const allGuides = await getCollection('guides')
const currentTags: string[] = guide.data.tags ?? []
const related = allGuides
  .filter((g) => g.id !== guide.id)
  .map((g) => {
    const pTags: string[] = g.data.tags ?? []
    const tagScore = pTags.filter((t) => currentTags.includes(t)).length
    return { g, tagScore }
  })
  .sort((a, b) => b.tagScore - a.tagScore)
  .slice(0, 3)
  .map((r) => r.g)
---

<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  ogImage={guide.data.heroImage?.src}
  ogType="article"
  narrow
>
  <SchemaOrg
    type="Article"
    title={guide.data.title}
    description={guide.data.description}
    publishedAt={guide.data.publishedAt}
  />
  <SchemaOrg
    type="BreadcrumbList"
    items={[
      { name: 'Home', url: `${SITE_URL}/` },
      { name: 'Guides', url: `${SITE_URL}/guides/` },
      { name: guide.data.title, url: Astro.url.href },
    ]}
  />

  <ReadingProgress />

  <article>
    <div class="mb-8 pb-6 border-b border-slate-200">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Guides', href: '/guides' },
        { label: guide.data.title },
      ]} />
      <div class="flex items-center gap-2 mt-4 mb-3">
      <DifficultyBadge difficulty={guide.data.difficulty} />
      <a href="/guides"
        class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300 no-underline hover:bg-emerald-200 dark:hover:bg-emerald-800 transition-colors">
        Guide
      </a>
      {guide.data.category && (
        <a href={`/categories/${guide.data.category}`}
          class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 no-underline hover:bg-slate-200 dark:hover:bg-slate-700 capitalize transition-colors">
          {guide.data.category}
        </a>
      )}
    </div>

      <h1 class="text-3xl font-bold text-slate-900 mt-2 mb-2">{guide.data.title}</h1>
      <p class="text-slate-500 mb-2">{guide.data.description}</p>
      
      <div class="flex gap-2 items-center text-sm text-slate-400 mb-2">
        <span>⏱ {guide.data.estimatedTime}</span>
        <span>·</span>
        <span>Published {publishedDate}</span>
      </div>
      
      {guide.data.tags && guide.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {guide.data.tags.map((tag: string) => (
            <a href={`/tags/${tag}`}
              class="text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-950 no-underline transition-colors">
              #{tag}
            </a>
          ))}
        </div>
      )}
      <ShareButtons title={guide.data.title} url={Astro.url.href} />
      
    </div>

    {guide.data.answerBox && (
      <AnswerBox
        question={guide.data.answerBox.question}
        shortAnswer={guide.data.answerBox.shortAnswer}
      />
    )}

    {guide.data.heroImage && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <Image
          src={guide.data.heroImage}
          alt={guide.data.heroImageAlt || guide.data.title}
          width={1200}
          height={630}
          class="w-full h-auto"
        />
      </div>
    )}

    {headings.length > 0 && (
      <TableOfContents headings={headings} variant="mobile" />
    )}

    <div class="lg:flex lg:gap-12 lg:items-start">
      <div class="lg:flex-1 min-w-0">
        <div class="post-body prose">
          <Content />
        </div>
        {guide.data.faq && <FAQSection items={guide.data.faq} />}
        <AuthorBox />
        <NewsletterBox />
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-56 shrink-0 sticky top-24 self-start">
          <TableOfContents headings={headings} variant="desktop" />
        </aside>
      )}
    </div>

    <RelatedPosts posts={related} title="More Guides" basePath="/guides/" />

  </article>

  <ProjectBanner />
</BaseLayout>