---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'

const PER_PAGE = 6
const allGuides = await getCollection('guides')
const sorted = allGuides.sort((a, b) =>
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
)
const totalPages = Math.ceil(sorted.length / PER_PAGE)
const guides = sorted.slice(0, PER_PAGE)

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300',
  intermediate: 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300',
  advanced: 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300',
}
---

<BaseLayout title="Guides — Astro Content Lab">
  <div class="mb-10 pb-6 border-b border-slate-200 dark:border-slate-700">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Guides</h1>
    <p class="text-slate-500 dark:text-slate-400 m-0">Step-by-step guides for building with Astro.</p>
  </div>

  <div class="flex flex-col gap-4">
    {guides.map((guide) => (
      <a href={`/guides/${guide.id}`} class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 border border-slate-200 dark:border-slate-700 dark:bg-slate-800/50 rounded-xl no-underline text-slate-900 dark:text-slate-100 hover:border-indigo-500 dark:hover:border-indigo-400 hover:shadow-sm transition-all group">
        {guide.data.heroImage && (
          <div class="flex-shrink-0 w-full h-44 sm:w-28 sm:h-16 rounded-lg overflow-hidden">
            <Image
              src={guide.data.heroImage}
              alt={guide.data.heroImageAlt || guide.data.title}
              width={400}
              height={210}
              class="w-full h-full object-cover"
            />
          </div>
        )}
        <div class="flex-1 min-w-0">
          <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mb-1 capitalize ${difficultyColors[guide.data.difficulty] ?? 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'}`}>
            {guide.data.difficulty}
          </span>
          <h2 class="text-base font-semibold m-0 mb-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{guide.data.title}</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 m-0">{guide.data.description}</p>
          <p class="text-sm text-slate-400 dark:text-slate-500 mt-1 m-0">⏱ {guide.data.estimatedTime}</p>
        </div>
        <span class="text-sm text-indigo-600 dark:text-indigo-400 font-medium whitespace-nowrap flex-shrink-0 sm:ml-auto">Read guide →</span>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={1}
    lastPage={totalPages}
    urlPrev={undefined}
    urlNext={totalPages > 1 ? '/guides/2/' : undefined}
    basePath="/guides"
  />
</BaseLayout>