---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allGuides = await getCollection('guides')
const sorted = allGuides.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})

const featuredGuide = sorted[0]
const restGuides = sorted.slice(1)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}

const allTags = [...new Set(sorted.flatMap(p => p.data.tags ?? []))] as string[]
const difficulties = ['beginner', 'intermediate', 'advanced']

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300',
  intermediate: 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300',
  advanced: 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300',
}
---

<BaseLayout title="Guides — Astro Content Lab">

  <div class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">🗺️</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Guides</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-3">Step-by-step guides for building with Astro.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">{allGuides.length} guides</span>
  </div>

  <!-- Difficulty tabs -->
  <div class="mb-4 flex flex-wrap gap-2" id="difficulty-filter">
    <button data-difficulty=""
      class="diff-btn active-diff text-xs font-semibold px-3 py-1.5 rounded-full border border-emerald-500 bg-emerald-500 text-white transition-all">
      All
    </button>
    {difficulties.map(d => (
      <button data-difficulty={d}
        class="diff-btn text-xs font-semibold px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:border-emerald-400 hover:text-emerald-600 transition-all capitalize">
        {d}
      </button>
    ))}
  </div>

  <!-- Tag pills -->
  <div class="mb-8 flex flex-wrap gap-2">
    {allTags.map(tag => (
      <button data-tag={tag}
        class="tag-btn text-xs px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-emerald-50 dark:hover:bg-emerald-950 hover:text-emerald-600 dark:hover:text-emerald-400 transition-all">
        #{tag}
      </button>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" class="hidden text-center py-16 text-slate-400 dark:text-slate-500">
    <p class="text-lg mb-2">No guides found</p>
    <button id="clear-filter" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">Clear filter</button>
  </div>

  <!-- Featured guide -->
  {featuredGuide && (
    <div class="mb-10 post-card"
      data-difficulty={featuredGuide.data.difficulty}
      data-tags={JSON.stringify(featuredGuide.data.tags ?? [])}>
      <a href={`/guides/${featuredGuide.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline">
        {featuredGuide.data.heroImage && (
          <div class="overflow-hidden h-52 sm:h-64">
            <Image src={featuredGuide.data.heroImage} alt={featuredGuide.data.heroImageAlt || featuredGuide.data.title} width={1200} height={630} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
        )}
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full capitalize ${difficultyColors[featuredGuide.data.difficulty] ?? 'bg-slate-100 dark:bg-slate-800 text-slate-600'}`}>
              {featuredGuide.data.difficulty}
            </span>
            {isNew(featuredGuide.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">{featuredGuide.data.title}</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-3">{featuredGuide.data.description}</p>
          <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500">
            <span>⏱ {featuredGuide.data.estimatedTime}</span>
            <span>·</span>
            <span>{new Date(featuredGuide.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>
      </a>
    </div>
  )}

  <!-- Grid guides -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">
    {restGuides.map((guide) => (
      <div class="post-card"
        data-difficulty={guide.data.difficulty}
        data-tags={JSON.stringify(guide.data.tags ?? [])}>
        <a href={`/guides/${guide.id}`}
          class="group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full">
          <div class="overflow-hidden h-40 bg-slate-100 dark:bg-slate-700">
            {guide.data.heroImage ? (
              <Image src={guide.data.heroImage} alt={guide.data.heroImageAlt || guide.data.title} width={400} height={210} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-emerald-50 to-slate-100 dark:from-emerald-950 dark:to-slate-800" />
            )}
          </div>
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full capitalize ${difficultyColors[guide.data.difficulty] ?? 'bg-slate-100 dark:bg-slate-800 text-slate-600'}`}>
                {guide.data.difficulty}
              </span>
              {isNew(guide.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h2 class="text-sm font-semibold mb-1 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors line-clamp-2">{guide.data.title}</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{guide.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-xs text-slate-400 dark:text-slate-500">⏱ {guide.data.estimatedTime}</span>
              <span class="text-xs text-emerald-600 dark:text-emerald-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

</BaseLayout>

<script>
  const diffBtns = document.querySelectorAll('.diff-btn')
  const tagBtns = document.querySelectorAll('.tag-btn')
  const cards = document.querySelectorAll('.post-card')
  const noResults = document.getElementById('no-results')
  const clearBtn = document.getElementById('clear-filter')
  let activeDiff = ''
  let activeTag = ''

  function filterCards() {
    let visible = 0
    cards.forEach((card) => {
      const el = card as HTMLElement
      const cardDiff = el.dataset.difficulty ?? ''
      const cardTags: string[] = JSON.parse(el.dataset.tags ?? '[]')
      const matchDiff = !activeDiff || cardDiff === activeDiff
      const matchTag = !activeTag || cardTags.includes(activeTag)
      el.style.display = matchDiff && matchTag ? '' : 'none'
      if (matchDiff && matchTag) visible++
    })
    noResults!.classList.toggle('hidden', visible > 0)
  }

  diffBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      activeDiff = el.dataset.difficulty ?? ''
      diffBtns.forEach(b => {
        b.classList.remove('active-diff', 'bg-emerald-500', 'border-emerald-500', 'text-white')
        b.classList.add('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')
      })
      el.classList.add('active-diff', 'bg-emerald-500', 'border-emerald-500', 'text-white')
      el.classList.remove('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')
      filterCards()
    })
  })

  tagBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement
      const tag = el.dataset.tag ?? ''
      if (activeTag === tag) {
        activeTag = ''
        el.classList.remove('bg-emerald-100', 'text-emerald-600')
        el.classList.add('bg-slate-100', 'text-slate-500')
      } else {
        activeTag = tag
        tagBtns.forEach(b => {
          b.classList.remove('bg-emerald-100', 'text-emerald-600')
          b.classList.add('bg-slate-100', 'text-slate-500')
        })
        el.classList.add('bg-emerald-100', 'text-emerald-600')
        el.classList.remove('bg-slate-100', 'text-slate-500')
      }
      filterCards()
    })
  })

  clearBtn?.addEventListener('click', () => {
    activeDiff = ''
    activeTag = ''
    diffBtns.forEach(b => {
      b.classList.remove('active-diff', 'bg-emerald-500', 'border-emerald-500', 'text-white')
      b.classList.add('border-slate-200', 'dark:border-slate-700', 'text-slate-600', 'dark:text-slate-400')
    })
    const allBtn = document.querySelector('[data-difficulty=""]') as HTMLElement
    allBtn?.classList.add('active-diff', 'bg-emerald-500', 'border-emerald-500', 'text-white')
    tagBtns.forEach(b => {
      b.classList.remove('bg-emerald-100', 'text-emerald-600')
      b.classList.add('bg-slate-100', 'text-slate-500')
    })
    filterCards()
  })
</script>