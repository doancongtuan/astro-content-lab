---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Pagination from '../../components/Pagination.astro'

const PER_PAGE = 7
const allGuides = await getCollection('guides')
const sorted = allGuides.sort((a, b) => {
  const dateDiff = new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  return dateDiff !== 0 ? dateDiff : a.id.localeCompare(b.id)
})
const totalPages = Math.ceil(sorted.length / PER_PAGE)
const guides = sorted.slice(0, PER_PAGE)

const featuredGuide = guides[0]
const restGuides = guides.slice(1)

const sevenDaysAgo = new Date()
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7)

function isNew(date: string | Date) {
  return new Date(date) > sevenDaysAgo
}

const difficultyColors: Record<string, string> = {
  beginner: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300',
  intermediate: 'bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300',
  advanced: 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300',
}
---

<BaseLayout title="Guides — Astro Content Lab">

  <!-- Hero -->
  <div class="mb-10 pb-8 border-b border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">🗺️</span>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 m-0">Guides</h1>
    </div>
    <p class="text-slate-500 dark:text-slate-400 m-0 mb-3">Step-by-step guides for building with Astro.</p>
    <span class="text-sm text-slate-400 dark:text-slate-500">{allGuides.length} guides</span>
  </div>

  <!-- Featured guide -->
  {featuredGuide && (
    <div class="mb-10 fade-up">
      
      <a  href={`/guides/${featuredGuide.id}`}
        class="group block border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-2xl overflow-hidden hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline"
      >
        {featuredGuide.data.heroImage && (
          <div class="overflow-hidden h-52 sm:h-64">
            <Image
              src={featuredGuide.data.heroImage}
              alt={featuredGuide.data.heroImageAlt || featuredGuide.data.title}
              width={1200}
              height={630}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
        )}
        <div class="p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full capitalize ${difficultyColors[featuredGuide.data.difficulty] ?? 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'}`}>
              {featuredGuide.data.difficulty}
            </span>
            {isNew(featuredGuide.data.publishedAt) && (
              <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
            )}
          </div>
          <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
            {featuredGuide.data.title}
          </h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-3">{featuredGuide.data.description}</p>
          <div class="flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500">
            <span>⏱ {featuredGuide.data.estimatedTime}</span>
            <span>·</span>
            <span>{new Date(featuredGuide.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>
      </a>
    </div>
  )}

  <!-- Grid guides -->
  {restGuides.length > 0 && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">
      {restGuides.map((guide) => (
        
        <a href={`/guides/${guide.id}`}
          class="fade-up group flex flex-col border border-slate-200 dark:border-slate-700 dark:bg-slate-800 rounded-xl overflow-hidden no-underline text-slate-900 dark:text-slate-100 hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
        >
          {guide.data.heroImage && (
            <div class="overflow-hidden h-40">
              <Image
                src={guide.data.heroImage}
                alt={guide.data.heroImageAlt || guide.data.title}
                width={400}
                height={210}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </div>
          )}
          <div class="p-4 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-2">
              <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full capitalize ${difficultyColors[guide.data.difficulty] ?? 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'}`}>
                {guide.data.difficulty}
              </span>
              {isNew(guide.data.publishedAt) && (
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300">New</span>
              )}
            </div>
            <h2 class="text-sm font-semibold mb-1 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors line-clamp-2">{guide.data.title}</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 flex-1">{guide.data.description}</p>
            <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100 dark:border-slate-700">
              <span class="text-xs text-slate-400 dark:text-slate-500">⏱ {guide.data.estimatedTime}</span>
              <span class="text-xs text-emerald-600 dark:text-emerald-400 font-medium">Read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}

  <Pagination
    currentPage={1}
    lastPage={totalPages}
    urlPrev={undefined}
    urlNext={totalPages > 1 ? '/guides/2/' : undefined}
    basePath="/guides"
  />

</BaseLayout>